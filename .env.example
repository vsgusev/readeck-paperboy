# =============================================================================
# readeck-paperboy configuration
# =============================================================================

# --- Required ---

READECK_URL=https://readeck.example.com
READECK_TOKEN=replace-me

# SMTP for outbound mail. Use an app password for Gmail / Yandex / Mail.ru.
SMTP_HOST=smtp.gmail.com
SMTP_USER=you@gmail.com
SMTP_PASS=replace-me

# IMPORTANT: Amazon only accepts documents emailed from an address on your
# "Approved Personal Document E-mail List". Add the sender (SMTP_FROM, or
# SMTP_USER if SMTP_FROM is unset) there, otherwise mail is silently dropped
# and nothing reaches the Kindle. Open amazon.com/hz/mycd/myx (use the
# regional domain for your account, e.g. amazon.co.jp / amazon.de) →
# Preferences → Personal Document Settings.

# Comma-separated list of destinations. Format: name:kindle-email
# Names must be lowercase letters/digits/underscores/dashes only.
# Example for a family: DESTINATIONS=vlad:vlad_xxx@kindle.com,anya:anya_yyy@kindle.com
DESTINATIONS=me:replace_me@kindle.com

# Name from DESTINATIONS used when a bookmark has the bare 'kindle' label
# (without a -{name} suffix). Must exist in DESTINATIONS.
DEFAULT_DESTINATION=me

# --- Optional ---

# SMTP port. 465 = implicit TLS (default); any other port (e.g. 587) = STARTTLS.
# SMTP_PORT=465
# SMTP_FROM=${SMTP_USER}

# How often to poll Readeck. Format: 30s, 5m, 1h, 24h. Default: 1h.
# POLL_INTERVAL=1h

# Set to false if your Readeck uses a self-signed certificate
# (e.g. Caddy's `tls internal`). Default: true.
# VERIFY_SSL=true

# Port inside the container where /healthz is served. Default: 8080.
# HEALTHCHECK_PORT=8080

# Logging verbosity: DEBUG, INFO, WARNING, ERROR. Default: INFO.
# LOG_LEVEL=INFO
